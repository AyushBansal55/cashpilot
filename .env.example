# Cashpilot environment variables.
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real .env — it is gitignored. No API keys in source code.

# --- Gemini access (required) ----------------------------------------------
# Get a free key from Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Tells ADK to use the AI Studio key above (set to 1) rather than Vertex AI.
GOOGLE_GENAI_USE_VERTEXAI=0

# --- Optional overrides (sensible defaults live in config.py) ---------------
# CASHPILOT_MODEL=gemini-flash-latest
# CASHPILOT_RISK_THRESHOLD=5000
# CASHPILOT_HORIZON_DAYS=90
